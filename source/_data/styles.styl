// ================================================
// 自定义华丽化样式（通过 NexT custom_file_path 注入）
// ================================================

// ---------- 主色调 ----------
$accent = #37c6c0
$accent2 = #7c4dff

// ---------- 页面背景：淡淡的渐变 ----------
body {
  background: linear-gradient(135deg, #f0fbfa 0%, #f6f4ff 50%, #fdf6f9 100%);
  background-attachment: fixed;
}

// ---------- 站点标题：渐变文字 ----------
.site-title {
  background: linear-gradient(90deg, #37c6c0, #7c4dff, #ff6b9d);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: bold;
}

// ---------- 内容/侧栏卡片：圆角 + 柔和阴影 + 悬浮效果 ----------
.content-wrap, .sidebar-inner, .post-block {
  border-radius: 14px;
  box-shadow: 0 4px 20px rgba(60, 80, 150, 0.08);
}

// Gemini 首页卡片悬浮反馈
.post-block {
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}
.post-block:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 32px rgba(60, 80, 150, 0.16);
}

// ---------- 首页：紧凑标题列表 ----------
// 整个列表装进一张大卡片
.main-inner.index {
  background: var(--content-bg-color);
  border-radius: 14px;
  box-shadow: 0 4px 20px rgba(60, 80, 150, 0.08);
  padding: 12px 32px;
}
// 每篇文章一行：去掉卡片感
.index .post-block {
  background: transparent;
  box-shadow: none;
  border-radius: 0;
  margin: 0;
  padding: 14px 4px;
  border-bottom: 1px dashed rgba(128, 128, 128, 0.25);
}
.index .post-block:last-of-type {
  border-bottom: none;
}
.index .post-block:hover {
  transform: none;
  box-shadow: none;
  background: linear-gradient(90deg, rgba(55, 198, 192, 0.06), rgba(124, 77, 255, 0.06));
  border-radius: 8px;
}
// 标题行：标题在左，日期在右
.index .posts-expand .post-header {
  border-bottom: none;
  margin: 0;
  padding: 0;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 12px;
}
.index .posts-expand .post-title {
  font-size: 1.05em;
  text-align: left;
  line-height: 1.5;
}
.index .posts-expand .post-meta-container {
  font-size: 0.8em;
  margin: 0;
  white-space: nowrap;
}
// 隐藏简介和按钮
.index .posts-expand .post-body,
.index .posts-expand .post-button {
  display: none;
}
// 手机端日期换行显示
@media (max-width: 567px) {
  .index .posts-expand .post-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }
}

// “阅读全文”按钮：渐变胶囊
.post-button .btn {
  background: linear-gradient(90deg, #37c6c0, #7c4dff);
  color: #fff !important;
  border: none;
  border-radius: 999px;
  padding: 4px 18px;
  transition: all 0.25s ease;
}
.post-button .btn:hover {
  opacity: 0.85;
  transform: scale(1.05);
}

// ---------- 文章标题悬浮渐变 ----------
.post-title-link {
  transition: all 0.25s ease;
}
.post-title-link:hover {
  background: linear-gradient(90deg, #37c6c0, #7c4dff);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

// ---------- 正文标题：左侧渐变竖条 ----------
.post-body h2 {
  padding-left: 12px;
  border-left: 4px solid $accent;
  border-image: linear-gradient(180deg, #37c6c0, #7c4dff) 1;
}
.post-body h3 {
  padding-left: 10px;
  border-left: 3px solid alpha($accent2, 0.6);
}

// ---------- 头像：渐变光环 ----------
.site-author-image {
  border: 3px solid transparent !important;
  background: linear-gradient(white, white) padding-box,
              linear-gradient(135deg, #37c6c0, #7c4dff, #ff6b9d) border-box;
  box-shadow: 0 0 18px rgba(124, 77, 255, 0.35);
}

// ---------- 菜单项悬浮 ----------
.menu-item a:hover, .menu-item a.menu-item-active {
  background-image: linear-gradient(90deg, rgba(55, 198, 192, 0.12), rgba(124, 77, 255, 0.12));
  border-radius: 8px;
}

// ---------- 标签/分类小胶囊 ----------
.post-tags a, .tag-cloud a {
  border-radius: 999px;
  padding: 1px 10px;
  transition: all 0.25s ease;
}
.post-tags a:hover, .tag-cloud a:hover {
  background: linear-gradient(90deg, #37c6c0, #7c4dff);
  color: #fff !important;
  border-color: transparent;
}

// ---------- 正文图片：圆角 + 轻阴影 ----------
.post-body img {
  border-radius: 8px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

// ---------- 引用块 ----------
.post-body blockquote {
  border-left: 4px solid $accent;
  background: linear-gradient(90deg, rgba(55, 198, 192, 0.07), transparent);
  border-radius: 0 8px 8px 0;
}

// ---------- 表格表头 ----------
.post-body table thead th {
  background: linear-gradient(90deg, rgba(55, 198, 192, 0.12), rgba(124, 77, 255, 0.12));
}

// ---------- 代码块圆角 ----------
.post-body .highlight, .post-body pre {
  border-radius: 10px;
}

// ---------- 选中文字颜色 ----------
::selection {
  background: rgba(124, 77, 255, 0.25);
}

// ---------- 彩色滚动条 ----------
::-webkit-scrollbar {
  width: 9px;
  height: 9px;
}
::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, #37c6c0, #7c4dff);
  border-radius: 999px;
}
::-webkit-scrollbar-track {
  background: transparent;
}

// ---------- 返回顶部按钮 ----------
.back-to-top {
  background: linear-gradient(135deg, #37c6c0, #7c4dff);
  border-radius: 10px;
}

// ---------- 深色模式适配 ----------
@media (prefers-color-scheme: dark) {
  body {
    background: linear-gradient(135deg, #0e1a1f 0%, #141225 50%, #1d1420 100%);
    background-attachment: fixed;
  }
  .content-wrap, .sidebar-inner {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.35);
  }
  .site-author-image {
    background: linear-gradient(#222, #222) padding-box,
                linear-gradient(135deg, #37c6c0, #7c4dff, #ff6b9d) border-box;
  }
}
